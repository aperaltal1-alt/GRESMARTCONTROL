# ===========================================
# GRE SMART CONTROL API — Variables de entorno
# ===========================================
# Desarrollo: copiar a .env
# Producción: configurar en Render Dashboard
# ===========================================

# --- Entorno ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# --- Base de datos ---
# Desarrollo: PostgreSQL local (docker compose up -d)
DATABASE_URL=postgresql://gre_admin:gre_secret_2024@localhost:5432/gre_smart_control?schema=public
DIRECT_DATABASE_URL=postgresql://gre_admin:gre_secret_2024@localhost:5432/gre_smart_control?schema=public

# Producción (Supabase):
# DATABASE_URL=postgresql://postgres.[REF]:[PASS]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# DIRECT_DATABASE_URL=postgresql://postgres.[REF]:[PASS]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# --- JWT ---
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS (URL del frontend) ---
# Desarrollo:
CORS_ORIGIN=http://localhost:3000
# Producción:
# CORS_ORIGIN=https://tu-app.vercel.app

# --- API ---
API_PREFIX=api

# --- Logging ---
LOG_LEVEL=info

# --- Rate Limit ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Swagger (deshabilitado en producción por defecto) ---
SWAGGER_ENABLED=true
SWAGGER_TITLE=GRE Smart Control API
SWAGGER_DESCRIPTION=API REST para conciliación inteligente de GRE, Kardex e Inventario
SWAGGER_VERSION=1.0
SWAGGER_PATH=docs

# --- Uploads ---
# Nota: en Render el filesystem es efímero. Para producción usar almacenamiento externo.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
