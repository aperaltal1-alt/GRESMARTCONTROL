# URL de la API (Render en producción)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# URL pública del frontend (Vercel en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_NAME=GRE Smart Control

