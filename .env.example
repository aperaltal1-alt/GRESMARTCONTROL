# =============================================================================
# GRE SMART CONTROL — Variables de entorno (referencia)
# =============================================================================
# Copia los valores según el entorno:
#   Desarrollo  → apps/api/.env  y  apps/web/.env
#   Producción  → Render (API) y Vercel (Web) dashboards
# =============================================================================

# -----------------------------------------------------------------------------
# DESARROLLO LOCAL
# -----------------------------------------------------------------------------

# --- API (apps/api/.env) ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# PostgreSQL local (Docker Compose)
DATABASE_URL=postgresql://gre_admin:gre_secret_2024@localhost:5432/gre_smart_control?schema=public
DIRECT_DATABASE_URL=postgresql://gre_admin:gre_secret_2024@localhost:5432/gre_smart_control?schema=public

JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
API_PREFIX=api
LOG_LEVEL=info
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
SWAGGER_ENABLED=true
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# --- Web (apps/web/.env) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GRE Smart Control

# -----------------------------------------------------------------------------
# PRODUCCIÓN (Supabase + Render + Vercel)
# -----------------------------------------------------------------------------

# --- API en Render ---
# NODE_ENV=production
# PORT=10000
# APP_URL=https://gre-smart-api.onrender.com
#
# Supabase — usar pooler (6543) para runtime y directo (5432) para migraciones
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# DIRECT_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#
# JWT_SECRET=<generar-secreto-seguro-64-chars>
# JWT_REFRESH_SECRET=<generar-secreto-seguro-64-chars>
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
#
# CORS_ORIGIN=https://gre-smart-control.vercel.app
# API_PREFIX=api
# LOG_LEVEL=info
# SWAGGER_ENABLED=false
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760

# --- Web en Vercel ---
# NEXT_PUBLIC_API_URL=https://gre-smart-api.onrender.com/api
# NEXT_PUBLIC_APP_URL=https://gre-smart-control.vercel.app
# NEXT_PUBLIC_APP_NAME=GRE Smart Control
